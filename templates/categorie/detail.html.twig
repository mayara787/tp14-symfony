{% extends 'base.html.twig' %}

{% block title %}{{ categorie.nom }}{% endblock %}

{% block body %}
    <h1 class="display-4">{{ categorie.nom }}</h1>
    {% if categorie.description %}
        <p class="text-muted mb-4 pb-2 border-bottom">{{ categorie.description }}</p>
    {% endif %}

    <p class="mb-4">
        📂 Nombre d'articles : {{ categorie.articles|length }}
        <a href="{{ path('app_article_nouveau', {categorie: categorie.id}) }}" class="btn btn-sm btn-success ms-2">
            ➕ Ajouter un article
        </a>
    </p>

    {# Liste des articles de la catégorie #}
    {% if categorie.articles|length > 0 %}
        <ul class="list-group mb-5">
            {% for article in categorie.articles %}
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <a href="{{ path('app_article_detail', {id: article.id}) }}">{{ article.titre }}</a>
                    <span class="badge bg-secondary">{{ article.dateCreation|date('d/m/Y') }}</span>
                </li>
            {% endfor %}
        </ul>
    {% else %}
        <p class="text-muted">Aucun article dans cette catégorie.</p>
    {% endif %}

    {# Boutons d'action #}
    <div class="d-flex gap-2 align-items-center">
        <a href="{{ path('app_categorie_modifier', {id: categorie.id}) }}" class="btn btn-primary">
            ✏️ Modifier
        </a>
        
        <form method="post" action="{{ path('app_categorie_supprimer', {id: categorie.id}) }}"
              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette catégorie ?');" class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('supprimer_' ~ categorie.id) }}">
            <button type="submit" class="btn btn-danger">🗑️ Supprimer</button>
        </form>

        <a href="{{ path('app_categories') }}" class="btn btn-outline-secondary">
            ← Retour à la liste
        </a>
    </div>
{% endblock %}